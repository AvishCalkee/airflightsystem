<core:FragmentDefinition xmlns:core="sap.ui.core"
    xmlns:m="sap.m">
    <m:Dialog id="crewDialog" title="Crew Members" afterClose="onDialogClose" contentWidth="100%">
        <m:List id='crewList' mode="SingleSelectMaster" items="{crewModel>/items}" headerText="{= 'Crew ('+ ${crewModel>/items}.length + ')' }">
            <m:ObjectListItem title="ID: {crewModel>CrewId}" type="Active" press="onCrewItemPress">
                <m:firstStatus>
                    <m:ObjectStatus text="{crewModel>Role}" state="Success"/>
                </m:firstStatus>
                <m:ObjectAttribute text="Firstname: {crewModel>FirstName}" />
			<m:ObjectAttribute text="Lastname: {crewModel>LastName}" />
			<m:markers>
				<m:ObjectMarker type="Favorite" />
				<m:ObjectMarker type="Flagged" />
			</m:markers>
            </m:ObjectListItem>
        </m:List>
        <m:buttons>
            <m:Button text="Select" press="fnGetSelectedCrew" type="Emphasized"/>
			<m:Button icon="sap-icon://action" type="Transparent" press="onDialogClose"/>
        </m:buttons>
    </m:Dialog>
</core:FragmentDefinition>